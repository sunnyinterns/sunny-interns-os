# ============================================================
# Sunny Interns OS — Variables d'environnement requises
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=                  # URL du projet Supabase (ex: https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=             # Clé publique Supabase (anon/public)
SUPABASE_SERVICE_ROLE_KEY=                 # Clé service role Supabase (serveur uniquement — ne jamais exposer côté client)
SUPABASE_URL=                              # Alias serveur de NEXT_PUBLIC_SUPABASE_URL
SUPABASE_PROJECT_REF=                      # Référence du projet Supabase (ex: djoqjgiyseobotsjqcgz)
SUPABASE_ACCESS_TOKEN=                     # Token d'accès Supabase CLI (pour migrations CI)

# ------ Auth Google OAuth ------
GOOGLE_CLIENT_ID=                          # Client ID Google OAuth 2.0
GOOGLE_CLIENT_SECRET=                      # Client Secret Google OAuth 2.0
GOOGLE_REFRESH_TOKEN=                      # Refresh token Google (compte service pour Calendar/Gmail)

# ------ IA — Anthropic & Google ------
ANTHROPIC_API_KEY=                         # Clé API Anthropic (Claude) — route /api/ai-assist
GOOGLE_AI_STUDIO_KEY=                      # Clé API Google AI Studio (Gemini) — fallback IA + génération images

# ------ Email — Resend ------
RESEND_API_KEY=                            # Clé API Resend
RESEND_FROM_EMAIL=                         # Adresse expéditrice par défaut (ex: team@bali-interns.com)

# ------ Notifications Push (VAPID) ------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=              # Clé publique VAPID pour Web Push
VAPID_PUBLIC_KEY=                          # Clé publique VAPID (serveur)
VAPID_PRIVATE_KEY=                         # Clé privée VAPID (serveur — confidentielle)
VAPID_EMAIL=                               # Email contact VAPID (ex: mailto:admin@bali-interns.com)

# ------ Monitoring — Sentry ------
NEXT_PUBLIC_SENTRY_DSN=                    # DSN public Sentry (client-side)
SENTRY_AUTH_TOKEN=                         # Token auth Sentry (upload source maps au build)

# ------ Sécurité interne ------
INTERNAL_API_KEY=                          # Clé secrète pour appels inter-services internes
CRON_SECRET=                               # Secret pour sécuriser les routes cron Vercel

# ------ Intégrations externes ------
SLACK_BOT_TOKEN=                           # Token bot Slack (notifications internes)
GITHUB_TOKEN=                              # Token GitHub (webhooks / API GitHub)
FIGMA_ACCESS_TOKEN=                        # Token d'accès Figma (si intégration design)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=           # Clé API Google Maps (affichage carte)

# ------ App ------
NEXT_PUBLIC_SITE_URL=                      # URL publique du site (ex: https://os.bali-interns.com)
NEXT_PUBLIC_APP_URL=                       # URL de l'app admin (peut être identique à SITE_URL)

# ------ Vercel (CI uniquement) ------
VERCEL_OIDC_TOKEN=                         # Token OIDC Vercel (injecté automatiquement en CI)
